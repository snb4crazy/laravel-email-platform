APP_NAME=EmailPlatform
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

# Deployment note:
# - This file is optimized for Azure VM but remains cloud-portable.
# - Keep CI/CD secrets (STAGING_*/PRODUCTION_* and *_SSH_KEY) in GitHub Environments.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Use managed SQL in production (Azure Database for MySQL/PostgreSQL or other cloud DB)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=email_platform
DB_USERNAME=email_user
DB_PASSWORD=change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_COOKIE=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=
# SESSION_CONNECTION=
# SESSION_TABLE=sessions
# SESSION_STORE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Optional queue tuning
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs
# DB_QUEUE=default
# DB_QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

CACHE_STORE=redis
# CACHE_PREFIX=

# Optional cache tuning
# DB_CACHE_CONNECTION=
# DB_CACHE_TABLE=cache
# DB_CACHE_LOCK_CONNECTION=
# DB_CACHE_LOCK_TABLE=
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
# MEMCACHED_PERSISTENT_ID=
# MEMCACHED_USERNAME=
# MEMCACHED_PASSWORD=

# For Azure Cache for Redis, set REDIS_HOST to your cache endpoint and use TLS port 6380 if required.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional cloud mail providers
# POSTMARK_API_KEY=
# RESEND_API_KEY=

# Future message attachment storage (Azure Blob)
AZURE_BLOB_ENABLED=false
AZURE_BLOB_DISK=azure_blob
AZURE_BLOB_DRIVER=local
AZURE_BLOB_VISIBILITY=private
AZURE_BLOB_PUBLIC_BASE_URL=
AZURE_BLOB_CONTAINER=message-attachments
AZURE_BLOB_PATH_PREFIX=messages
AZURE_BLOB_ACCOUNT_NAME=
AZURE_BLOB_ACCOUNT_KEY=
AZURE_BLOB_ENDPOINT_SUFFIX=core.windows.net
AZURE_BLOB_CONNECTION_STRING=

# Optional S3-compatible storage (AWS, MinIO, other clouds)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional DynamoDB cache support
# DYNAMODB_CACHE_TABLE=cache
# DYNAMODB_ENDPOINT=

# Draft auth scaffold (pass-through middleware for now)
DRAFT_AUTH_ENFORCE=false

DRAFT_CONTACT_REQUIRE_API_KEY=false
DRAFT_CONTACT_API_KEY_HEADER=X-Api-Key
DRAFT_CONTACT_CAPTCHA_ENABLED=false
DRAFT_CONTACT_CAPTCHA_PROVIDER=turnstile
DRAFT_CONTACT_CAPTCHA_SECRET=

DRAFT_WEBHOOK_REQUIRE_SIGNATURE=false
DRAFT_WEBHOOK_SIGNATURE_ALGO=sha256
DRAFT_WEBHOOK_ALLOWED_CLOCK_SKEW_SECONDS=300
DRAFT_WEBHOOK_HEADER_KEY_ID=X-Key-Id
DRAFT_WEBHOOK_HEADER_TIMESTAMP=X-Timestamp
DRAFT_WEBHOOK_HEADER_NONCE=X-Nonce
DRAFT_WEBHOOK_HEADER_CONTENT_SHA256=X-Content-SHA256
DRAFT_WEBHOOK_HEADER_SIGNATURE=X-Signature

# Draft multi-site settings (no enforcement yet)
MULTISITE_ENABLED=false
MULTISITE_REQUIRE_SITE_KEY=false
MULTISITE_ALLOW_CLIENT_SITE_ID=true

